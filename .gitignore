.env
.env.*
!.env.local.example
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.der
*secret*
*secrets*
!**/secrets-template*
!.github/**/*secret*
!.github/**/*secrets*
credentials.json
service-account*.json
gcp-key*.json
aws-credentials*

