# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Required by SupportAgent, FollowupAgent, PrescriptionAgent, QualificationAgent
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── Twilio (SMS / WhatsApp) ─────────────────────────────────────────────────
# Account credentials — Twilio Console > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
# E.164 format: +1XXXXXXXXXX
# Buy numbers in Twilio Console > Phone Numbers > Manage > Buy a number
TWILIO_SMS_NUMBER=+18005550100
# WhatsApp sender — must be approved in Twilio Console > Messaging > Senders > WhatsApp
# The value stored here is the raw number; the lib adds the "whatsapp:" prefix automatically.
TWILIO_WHATSAPP_NUMBER=+14155238886

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
# Arbitrary secret token used to authenticate /api/admin/* and /api/agents/* endpoints.
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=your-random-secret-token-here

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Phone number shown to patients in SMS/email for inbound support inquiries
SUPPORT_SMS_NUMBER=+18005550100

# ─── Compounding Pharmacy ────────────────────────────────────────────────────
# Used by PrescriptionAgent to populate prescription records and pharmacy API calls.
COMPOUNDING_PHARMACY_NAME=Precision Compounding Pharmacy
COMPOUNDING_PHARMACY_NPI=1234567890
COMPOUNDING_PHARMACY_DEA=AB1234567
# Your pharmacy partner's order API
PHARMACY_API_URL=https://api.yourpharmacy.com/v1/orders
PHARMACY_API_KEY=your-pharmacy-api-key

# ─── Prescriber (licensed physician of record) ───────────────────────────────
# NPI: National Provider Identifier (10 digits) — https://npiregistry.cms.hhs.gov/
PRESCRIBER_NPI=1234567890
# DEA number issued by the Drug Enforcement Administration
PRESCRIBER_DEA=AB1234567
# Full legal name as it appears on DEA registration
PRESCRIBER_NAME=Dr. Jane Smith MD
